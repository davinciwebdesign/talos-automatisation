---
import Icon from './Icon.astro';
/**
 * Testimonials. Until real, attributed testimonials exist (name + role +
 * company + concrete result), this renders a single neutral, honest
 * empty-state — no invented quotes, names or figures (ethics rule 5.8).
 * Pass real `items` to display them.
 */
interface Testimonial {
  quote: string;
  name: string;
  role: string;
  result?: string;
}
interface Props {
  items?: Testimonial[];
  columns?: 2 | 3;
}

const { items, columns = 3 } = Astro.props;
const hasItems = items && items.length > 0;
---

{hasItems ? (
<div class:list={['tlist', `cols-${columns}`]}>
  {
    items.map((t) => (
      <figure class="tcard surface">
        <Icon name="quote" size={26} class="tquote" />
        <blockquote class="tquote-text">{t.quote}</blockquote>
        {t.result && (
          <p class="tresult">
            <Icon name="trending" size={16} /> {t.result}
          </p>
        )}
        <figcaption class="tmeta">
          <span class="tavatar" aria-hidden="true">
            <Icon name="users" size={18} />
          </span>
          <span class="tnames">
            <span class="tname">{t.name}</span>
            <span class="trole">{t.role}</span>
          </span>
        </figcaption>
      </figure>
    ))
  }
</div>
) : (
<div class="tempty surface">
  <Icon name="quote" size={26} class="tquote" />
  <p class="tempty-text">Les premiers retours clients seront publiés ici, avec des résultats concrets et mesurés.</p>
</div>
)}

<style>
  .tlist {
    display: grid;
    gap: 1.25rem;
  }
  .cols-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .tcard {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.5rem;
    position: relative;
    transition:
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }
  .tcard:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-brand-300);
  }
  .tcard :global(.tquote) {
    transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .tavatar {
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      background-color 0.28s ease,
      color 0.28s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .tcard:hover :global(.tquote) {
      transform: scale(1.15) rotate(-6deg);
    }
    .tcard:hover .tavatar {
      transform: scale(1.08);
      background: var(--color-brand-50);
      color: var(--color-brand-700);
    }
  }
  .tempty {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    max-width: 52rem;
  }
  .tempty :global(.tquote) {
    color: var(--color-brand-400);
    flex: none;
  }
  .tempty-text {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .tcard :global(.tquote) {
    color: var(--color-brand-400);
  }
  .tquote-text {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--text);
  }
  .tresult {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
    font-weight: 700;
    color: var(--color-brand-700);
    font-size: 0.95rem;
  }
  :root[data-theme='dark'] .tresult {
    color: var(--color-brand-400);
  }
  .tmeta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }
  .tavatar {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 999px;
    background: var(--bg-muted);
    color: var(--text-muted);
    flex: none;
  }
  .tnames {
    display: flex;
    flex-direction: column;
  }
  .tname {
    font-weight: 700;
    font-size: 0.95rem;
  }
  .trole {
    font-size: 0.85rem;
    color: var(--text-subtle);
  }
  @media (max-width: 900px) {
    .cols-3 {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .cols-3,
    .cols-2 {
      grid-template-columns: 1fr;
    }
  }
</style>
