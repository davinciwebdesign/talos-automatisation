---
interface Step {
  title: string;
  body: string;
  outcome?: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---

<ol class="steps">
  {
    steps.map((s, i) => (
      <li class="step surface">
        <span class="step-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <div class="step-body">
          <h3 class="h4 step-title">{s.title}</h3>
          <p class="step-text">{s.body}</p>
          {s.outcome && (
            <p class="step-outcome">
              <strong>Ce que vous obtenez :</strong> {s.outcome}
            </p>
          )}
        </div>
      </li>
    ))
  }
</ol>

<style>
  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    counter-reset: step;
  }
  .step {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem;
    align-items: flex-start;
  }
  .step-num {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
    color: var(--color-accent-700);
    flex: none;
    width: 2.5rem;
  }
  :root[data-theme='dark'] .step-num {
    color: var(--color-accent-400);
  }
  .step-title {
    margin: 0 0 0.4rem;
  }
  .step-text {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .step-outcome {
    margin: 0.6rem 0 0;
    font-size: 0.95rem;
    color: var(--text);
  }
  @media (min-width: 760px) {
    .steps {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
