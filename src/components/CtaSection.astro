---
import Button from './Button.astro';
import Icon from './Icon.astro';
import { primaryCta } from '../config/site';
interface Props {
  title?: string;
  text?: string;
  track?: string;
}
const {
  title = 'Récupérez des heures chaque semaine',
  text = "Réservez un audit gratuit : nous identifions ensemble vos tâches automatisables et leur impact. Vous repartez avec un plan clair, même sans suite.",
  track = 'cta-section',
} = Astro.props;
---

<section class="cta-band">
  <div class="container-page">
    <div class="cta-inner">
      <div class="cta-copy">
        <p class="eyebrow"><Icon name="sparkles" size={16} /> Audit gratuit</p>
        <h2 class="h2 cta-title">{title}</h2>
        <p class="cta-text measure">{text}</p>
      </div>
      <div class="cta-card">
        <p class="cta-card-title">Ce que vous obtenez à l'audit</p>
        <ul class="cta-list">
          <li><Icon name="checkCircle" size={18} /> Un diagnostic de vos tâches chronophages</li>
          <li><Icon name="checkCircle" size={18} /> Une estimation du temps récupérable</li>
          <li><Icon name="checkCircle" size={18} /> Des pistes priorisées, sans engagement</li>
        </ul>
        <Button href={primaryCta.href} size="lg" block track={track}>
          {primaryCta.label}
        </Button>
        <p class="cta-note cta-note-light">
          <Icon name="check" size={16} /> {primaryCta.note}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    padding-block: clamp(3rem, 2rem + 4vw, 5rem);
    background: var(--contrast-bg);
    color: var(--contrast-text);
  }
  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .cta-copy {
    max-width: 38rem;
  }
  .cta-band :global(.eyebrow) {
    color: var(--contrast-eyebrow);
  }
  .cta-title {
    color: var(--contrast-heading);
    margin: 0.5rem 0 0.75rem;
  }
  .cta-text {
    color: var(--contrast-muted);
    margin: 0;
  }
  .cta-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    width: 100%;
    max-width: 22rem;
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--contrast-text) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--contrast-text) 14%, transparent);
  }
  .cta-card-title {
    margin: 0;
    font-weight: 700;
    color: var(--contrast-heading);
  }
  .cta-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .cta-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: var(--contrast-muted);
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .cta-list svg {
    flex: none;
    margin-top: 0.1rem;
    color: var(--contrast-eyebrow);
  }
  .cta-note-light {
    color: var(--contrast-muted);
  }
  @media (max-width: 720px) {
    .cta-card {
      max-width: none;
    }
  }
</style>
