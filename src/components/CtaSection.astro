---
import Button from './Button.astro';
import Icon from './Icon.astro';
import { primaryCta } from '../config/site';
interface Props {
  title?: string;
  text?: string;
  track?: string;
}
const {
  title = 'Récupérez des heures chaque semaine',
  text = "Réservez un audit gratuit : nous identifions ensemble vos tâches automatisables et leur impact. Vous repartez avec un plan clair, même sans suite.",
  track = 'cta-section',
} = Astro.props;
---

<section class="cta-band">
  <div class="container-page">
    <div class="cta-inner">
      <div class="cta-copy">
        <p class="eyebrow"><Icon name="sparkles" size={16} /> Audit gratuit</p>
        <h2 class="h2 cta-title">{title}</h2>
        <p class="cta-text measure">{text}</p>
      </div>
      <div class="cta-action">
        <Button href={primaryCta.href} size="lg" track={track}>
          {primaryCta.label}
        </Button>
        <p class="cta-note cta-note-light">
          <Icon name="check" size={16} /> {primaryCta.note}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    padding-block: clamp(3rem, 2rem + 4vw, 5rem);
    background: var(--contrast-bg);
    color: var(--contrast-text);
  }
  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .cta-copy {
    max-width: 38rem;
  }
  .cta-band :global(.eyebrow) {
    color: var(--contrast-eyebrow);
  }
  .cta-title {
    color: var(--contrast-heading);
    margin: 0.5rem 0 0.75rem;
  }
  .cta-text {
    color: var(--contrast-muted);
    margin: 0;
  }
  .cta-action {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.85rem;
  }
  .cta-note-light {
    color: var(--contrast-muted);
  }
  @media (max-width: 720px) {
    .cta-action {
      width: 100%;
    }
  }
</style>
