---
import Icon from './Icon.astro';
interface Props {
  icon?: string;
  title: string;
  text?: string;
  href?: string;
  linkLabel?: string;
  class?: string;
}
const { icon, title, text, href, linkLabel = 'En savoir plus', class: cls = '' } =
  Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag class:list={['card surface', href && 'card-link', cls]} href={href}>
  {
    icon && (
      <span class="card-icon" aria-hidden="true">
        <Icon name={icon} size={24} />
      </span>
    )
  }
  <h3 class="card-title h4">{title}</h3>
  {text && <p class="card-text">{text}</p>}
  <slot />
  {
    href && (
      <span class="card-cta">
        {linkLabel}
        <Icon name="arrowRight" size={16} />
      </span>
    )
  }
</Tag>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: clamp(1.25rem, 1rem + 1vw, 1.75rem);
    height: 100%;
    text-decoration: none;
    color: var(--text);
    transition:
      transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }
  .card:hover {
    border-color: var(--color-brand-300);
  }
  .card-link:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-brand-300);
  }
  .card-link:focus-visible {
    transform: translateY(-5px);
  }
  .card-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-md);
    background: var(--color-brand-50);
    color: var(--color-brand-700);
    margin-bottom: 0.35rem;
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      background-color 0.28s ease,
      color 0.28s ease;
  }
  @media (prefers-reduced-motion: no-preference) {
    .card:hover .card-icon {
      transform: translateY(-2px) scale(1.08) rotate(-4deg);
      background: var(--color-brand-700);
      color: #fff;
    }
    :root[data-theme='dark'] .card:hover .card-icon {
      background: var(--color-brand-400);
      color: #0b0b0f;
    }
  }
  :root[data-theme='dark'] .card-icon {
    background: rgb(255 255 255 / 0.08);
    color: var(--color-neutral-200);
  }
  .card-title {
    margin: 0;
  }
  .card-text {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.975rem;
    line-height: 1.55;
  }
  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: auto;
    padding-top: 0.5rem;
    color: var(--link);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .card-cta svg {
    transition: transform 0.15s ease;
  }
  .card-link:hover .card-cta svg {
    transform: translateX(3px);
  }
</style>
