---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Icon from '../components/Icon.astro';
import ContactForm from '../components/ContactForm.astro';
import { site } from '../config/site';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Contact' },
];
---

<Layout
  title="Contact"
  description="Une question sur l'automatisation de vos processus ? Écrivez-nous : réponse sous 24 h ouvrées. Vous pouvez aussi réserver directement un audit gratuit."
  breadcrumbs={breadcrumbs}
>
  <PageHero
    eyebrow="Contact"
    eyebrowIcon="mail"
    title="Parlons de vos tâches à automatiser"
    subtitle="Une question, un projet, un doute ? Écrivez-nous. On répond personnellement sous 24 h ouvrées."
    secondary={{ label: 'Envoyer un message', href: '#formulaire' }}
  />

  <Section tight>
    <div class="contact-grid">
      <div class="contact-form-col" id="formulaire">
        <h2 class="h3">Envoyez-nous un message</h2>
        <p class="contact-intro measure">
          Décrivez votre besoin en quelques lignes. Plus vous êtes précis sur la
          tâche qui vous pèse, plus notre première réponse sera utile.
        </p>
        <ContactForm variant="contact" formName="contact" />
      </div>

      <aside class="contact-aside">
        <div class="contact-card surface">
          <h2 class="contact-card-title">Coordonnées</h2>
          <ul class="contact-list">
            {site.email && (
              <li>
                <Icon name="mail" size={20} />
                <div>
                  <span class="cl-label">Email</span>
                  <a class="link" href={`mailto:${site.email}`}>{site.email}</a>
                </div>
              </li>
            )}
            {site.phone && (
              <li>
                <Icon name="phone" size={20} />
                <div>
                  <span class="cl-label">Téléphone</span>
                  <a class="link" href={`tel:${site.phone.replace(/\s/g, '')}`}>{site.phone}</a>
                </div>
              </li>
            )}
            <li>
              <Icon name="mapPin" size={20} />
              <div>
                <span class="cl-label">Zone d'intervention</span>
                <span>{site.area} — à distance et sur site</span>
              </div>
            </li>
            <li>
              <Icon name="clock" size={20} />
              <div>
                <span class="cl-label">Délai de réponse</span>
                <span>Sous 24 h ouvrées</span>
              </div>
            </li>
          </ul>
        </div>

        <div class="contact-card surface contact-alt">
          <h2 class="contact-card-title">Plutôt un échange direct ?</h2>
          <p class="contact-alt-text">
            Réservez un audit gratuit de 30 minutes : c'est le moyen le plus
            rapide d'obtenir des pistes concrètes.
          </p>
          <a class="link contact-alt-link" href="/audit-gratuit/">
            Réserver un audit gratuit <Icon name="arrowRight" size={16} />
          </a>
        </div>
      </aside>
    </div>
  </Section>
</Layout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(1.5rem, 1rem + 3vw, 3rem);
    align-items: start;
  }
  .contact-intro { margin: 0.5rem 0 1.75rem; color: var(--text-muted); }

  .contact-aside { display: grid; gap: 1.25rem; }
  .contact-card { padding: 1.75rem; }
  .contact-card-title { margin: 0 0 1.1rem; font-size: 1.2rem; }
  .contact-list { list-style: none; margin: 0; padding: 0; display: grid; gap: 1.1rem; }
  .contact-list li { display: flex; gap: 0.75rem; align-items: flex-start; }
  .contact-list svg { color: var(--color-brand-600); flex: none; margin-top: 0.15rem; }
  :root[data-theme='dark'] .contact-list svg { color: var(--color-brand-300); }
  .contact-list > li > div { display: flex; flex-direction: column; gap: 0.15rem; }
  .cl-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-subtle); }

  .contact-alt { background: var(--bg-muted); }
  .contact-alt-text { margin: 0 0 1rem; color: var(--text-muted); line-height: 1.55; }
  .contact-alt-link { display: inline-flex; align-items: center; gap: 0.35rem; font-weight: 600; }

  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
